APP_NAME=placement-trust-backend
APP_ENV=production
APP_VERSION=0.2.0
DOCS_ENABLED=false

# Use Postgres for production, or SQLite with a persistent disk for demos.
DATABASE_URL=sqlite:////var/data/placement_trust.db
MODEL_ARTIFACT_PATH=artifacts/trust_model.joblib

# Replace these in the hosting dashboard. Do not commit real values.
AUTH_SECRET_KEY=
ADMIN_REGISTRATION_KEY=

# Comma-separated frontend origins that may call the API.
CORS_ORIGINS=https://your-frontend.vercel.app
# Optional: allow all Vercel preview URLs for one project/team.
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Optional integrations.
GITHUB_TOKEN=
JUDGE0_BASE_URL=
JUDGE0_API_KEY=
JUDGE0_AUTH_TOKEN=
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_PROCTORING_DISABLED=false
RAPIDAPI_KEY=
JSEARCH_HOST=jsearch.p.rapidapi.com

