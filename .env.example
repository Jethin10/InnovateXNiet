APP_NAME=placement-trust-backend
APP_ENV=production
APP_VERSION=0.2.0
DOCS_ENABLED=false

# Free Render services do not support persistent disks, so this resets on redeploy/restart.
# Use Postgres or a paid service disk for persistent production data.
DATABASE_URL=sqlite:///./placement_trust.db
MODEL_ARTIFACT_PATH=artifacts/trust_model.joblib

# Replace these in the hosting dashboard. Do not commit real values.
AUTH_SECRET_KEY=
ADMIN_REGISTRATION_KEY=

# Comma-separated frontend origins that may call the API.
CORS_ORIGINS=https://your-frontend.vercel.app
# Optional: allow all Vercel preview URLs for one project/team.
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Optional integrations.
GITHUB_TOKEN=
JUDGE0_BASE_URL=
JUDGE0_API_KEY=
JUDGE0_AUTH_TOKEN=
JUDGE0_C_LANGUAGE_ID=50
JUDGE0_CPP_LANGUAGE_ID=54
JUDGE0_JAVA_LANGUAGE_ID=62
JUDGE0_JAVASCRIPT_LANGUAGE_ID=63
JUDGE0_PYTHON_LANGUAGE_ID=71
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_PROCTORING_DISABLED=false
RAPIDAPI_KEY=
JSEARCH_HOST=jsearch.p.rapidapi.com
